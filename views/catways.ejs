<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Gestion des Catways - Port Roussel</title>
</head>
<body>
    <h1>Gestion des Catways</h1>
    <p>Bienvenue dans l'espace de gestion des pontons et catways de la capitainerie.</p>

    <a href="/users/dashboard">⬅️ Retour au Tableau de bord</a>
    <hr>

    <h2>Ajouter un nouveau Catway</h2>
    <form action="/catways" method="POST">
        <input type="number" name="catwayNumber" placeholder="Numéro du Catway (ex: 12)" required>
        
        <select name="catwayType" required>
            <option value="">-- Type de Catway --</option>
            <option value="long">Long</option>
            <option value="short">Court</option>
        </select>
        
        <input type="text" name="catwayState" placeholder="État (ex: disponible)" required>
        <button type="submit">Créer le Catway</button>
    </form>

    <hr>

    <h2>Liste des Catways existants</h2>
    <!-- C'est ici qu'on affichera plus tard la vraie liste issue de MongoDB -->
    <table border="1" cellpadding="5" style="border-collapse: collapse;">
        <thead>
            <tr>
                <th>Numéro</th>
                <th>Type</th>
                <th>État</th>
                <th>Actions</th>
            </tr>
        </thead>
  <tbody>
    <% if (catways && catways.length > 0) { %>
        <% catways.forEach(catway => { %>
            <tr>
                <td><%= catway.catwayNumber %></td>
                <td><%= catway.catwayType %></td>
                <td><%= catway.catwayState %></td>
                <td>
                    <a href="/catways/<%= catway._id %>">
                        <button type="button">Modifier / Voir</button>
                    </a>

                    <form action="/catways/delete/<%= catway.catwayNumber %>" method="POST" style="display: inline; margin-left: 10px;">
                        <button type="submit" style="color: red; cursor: pointer;">
                            Supprimer
                        </button>
                    </form>
                </td>
            </tr>
        <% }) %>
    <% } else { %>
        <tr>
            <td colspan="4" style="text-align: center;">Aucun catway trouvé dans la base de données.</td>
        </tr>
    <% } %>
</tbody>
    </table>
</body>
</html>